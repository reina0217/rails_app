<h1><%= Article.model_name.human %></h1>

<main>
  <% @articles.each do |article| %>
    <div class='row mb-3'>
      <div class='col'>
        <div class='card'>
          <div class='card-body'>
            <%= image_tag article.image.url, class: 'img-fluid mb-3' if article.image.url %>
            <h5 class='card-title'><%= h article.title %></h5>
            <p class='card-text'><%= simple_format(h(article.text)) %></p>
          </div>
          <div class='card-footer'>
            <div class='float-right'>
              <%= link_to t('label.show'), article_path(article), class: 'btn btn-default btn-sm' %>
              <%= link_to t('label.edit'), edit_article_path(article), class: 'btn btn-default btn-sm' %>
              <%= link_to t('label.destroy'),
                    article_path(article), class: 'btn btn-outline-danger btn-sm',
                                           method: :delete,
                                           data: { confirm: t('label.destroy_confirm') } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</main>
